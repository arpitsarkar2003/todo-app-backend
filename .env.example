APP_NAME="Todo App Backend"
APP_VERSION="1.0.0"

# MongoDB
MONGODB_URI="mongodb://localhost:27017"
MONGODB_DB_NAME="todo_app_db"

# JWT
JWT_SECRET_KEY="change_me_to_a_long_random_value"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Admin seed user
ADMIN_EMAIL="admin@todo.com"
ADMIN_PASSWORD="todo@pass"

# Optional SMTP settings for real OTP emails.
# If these are not set, OTP codes will be printed to the console.
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USERNAME="smtp-user"
# SMTP_PASSWORD="smtp-password"
# SMTP_FROM_EMAIL="no-reply@example.com"

